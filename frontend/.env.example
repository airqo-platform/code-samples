# Server-only AirQo API token used by /api/airqo.
API_TOKEN=

# Public Mapbox token used by map views and reports.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Public endpoint used by the AQI heatmap component.
NEXT_PUBLIC_AQI_API_URL=

# Optional Google Analytics measurement ID.
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=

# AirQo account email that receives initial super-admin access.
ADMIN_EMAIL=

# Use a long random value (at least 32 characters) to sign admin sessions.
ADMIN_SESSION_SECRET=
